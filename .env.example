# ── Database ──────────────────────────────────────────────────────────────────
# Your PostgreSQL connection string.
# On Hostinger: copy from your database panel under "Connection details"
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE

# ── Server ────────────────────────────────────────────────────────────────────
# Port to listen on. Hostinger sets this automatically — leave as 3000 as fallback.
PORT=3000

# ── Environment ───────────────────────────────────────────────────────────────
NODE_ENV=production
