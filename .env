# ── Database ──────────────────────────────────────────────────────────────────
# Your PostgreSQL connection string.
# On Hostinger: copy from your database panel under "Connection details"
DATABASE_URL=postgresql://user:password@localhost:5432/returnride

# ── Server ────────────────────────────────────────────────────────────────────
# Port to listen on. Hostinger sets this automatically — leave as 3000 as fallback.
PORT=3000

# ── Environment ───────────────────────────────────────────────────────────────
NODE_ENV=production
GOOGLE_CLIENT_ID="515614032126-u303024g48lmlg89h47m7atoea3ij41q.apps.googleusercontent.com"
